# ==============================================================================
# Project-specific
# ==============================================================================
# Raw and pre-processed dataset (large — download/generate locally, see README)
data/raw/
data/patches/
data/*.csv

# Trained checkpoints (large binary files — keep your own outside git, or use
# Git LFS / Google Drive if you need to version them)
checkpoints/*.pth
checkpoints/*.pt
!checkpoints/.gitkeep

# Training logs (TensorBoard event files)
logs/*
!logs/.gitkeep

# Generated results/visualizations (regenerate via train.py/test.py)
results/*
!results/.gitkeep

